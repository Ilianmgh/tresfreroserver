<{
  let html_table_of_query = fun db query ->
    <[
      <table>
        <{
          Sqlite.exec db
            (fun acc new_line -> <[ <tr> <{new_line}> </tr> ]>)
            begin fun acc hd content ->
              <[ <{ acc }> <th> <{ hd }> </th> ]>
            end query
        }>
        <{
          Sqlite.exec db
            (fun acc new_line -> <[ <{acc}> <tr> <{new_line}> </tr> ]>)
            begin fun acc hd content ->
              <[ <{ acc }> <td> <{content}> </td> ]>
            end query
        }>
      </table>
    ]>

  let html_table_of_table = fun db table_name -> html_table_of_query db f"SELECT * FROM %{table_name}%"

  let closedb_with_alert = fun db ->
    if not (Sqlite.closedb db) then
      <[
        <script type="text/javascript">
          alert("Error while closing database");
        </script>
      ]>
    else
      <[]>
}>