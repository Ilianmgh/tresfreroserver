<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Admin connection</title>
    <style>
      .errorMessage {
        color: red
      }
    </style>
  </head>
  <body>
    <h1>Connect to admin panel</h1>
    <p>
      <form method="POST" action="connection_post.tml">
        <label>Database : </label><input id="1", type="text" name="database"></input><br/>
        <label>Mot de passe : </label><input id="2" type="password" name="password"></input><br/>
        <input type="submit" value="Envoyer">
      </form>
      <{
        if Get.connect = "failed" then <[
          <span class="errorMessage">Invalid password</span>
        ]> else <[]>
      }>
    </p>
  </body>
</html>