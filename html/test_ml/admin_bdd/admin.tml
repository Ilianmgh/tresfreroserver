<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Admin connection</title>
  </head>
  <body>
    <h1>Admin panel</h1>
    <h2>Query a database</h2>
    <p>
      <form method="POST" action="admin_post.tml">
        <label>Query : </label><textarea id="1" type="textbox" name="query" style="height: 200px; width: 1100px;"></textarea><br/>
        <label>Display result ? </label><input id="2" type="textbox" name="display"></input><br/>
        <input type="submit" value="Envoyer">
      </form>
    </p>
    <p>
    <{
      import "test_ml/sqlite_helper.tml" as SqliteTools
      let db = Sqlite.opendb Session.db_path
    }>
    <{ if Session.displayQuery then (* TODO evaluation fails with when single quotes appear *)
      <[
        <h2>Query result</h2>
        <p>
          <{ SqliteTools.html_table_of_query db Session.query }>
        </p>
      ]>
      else <[]>
    }>
    <{
      Sqlite.exec db
        (fun lines_acc new_line -> <[ <{ lines_acc }> <p> <{new_line}> </p> ]>)
        begin fun cells_acc hd content -> (* SqliteTools.html_table_of_table TODO: won't work until exec does not depend on expr_of_value anymore *) content
        end "SELECT name FROM sqlite_schema"
    }>
    <{ SqliteTools.closedb_with_alert db }>
    <{
      Session.let displayQuery = false (* re-establish to false so refreshing doesn't execute twice the query *)
    }>
    <{
      "couBACKSLASHNTOCOME\nBACKSLASHNJUSTCAMEcou"
    }>
    <{
      f"couBACKSLASHNTOCOME\nBACKSLASHNJUSTCAMEcou"
    }>
  </body>
</html>