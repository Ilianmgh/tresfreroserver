<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Admin connection</title>
  </head>
  <body>
    <h1>Admin panel</h1>
    <h2>Query a database</h2>
    <p>
      <form method="POST" action="admin_post.tml">
        <label>Database : </label><input id="1", type="text" name="database"></input><br/>
        <label>Query : </label><textarea id="2" type="textbox" name="query" style="height: 200px; width: 1100px;"></textarea><br/>
        <input type="submit" value="Envoyer">
      </form>
    </p>
    <p>
    <{ if Get.queryAsked = "true" then (* TODO evaluation fails with when single quotes appear *)
      <[
        <{
          import "test_ml/sqlite_helper.tml" as SqliteTools
          let db = Sqlite.opendb "./test.db"
        }>
        <h2>Query result</h2>
        <p>
          <{ SqliteTools.html_table_of_query db Get.query }>
        </p>
      ]>
      else <[]>
    }>
  </body>
</html>